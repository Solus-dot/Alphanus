{
  "schema_version": "1.0.0",
  "agent": {
    "model_endpoint": "http://127.0.0.1:8080/v1/chat/completions",
    "models_endpoint": "http://127.0.0.1:8080/v1/models",
    "request_timeout_s": 180,
    "readiness_timeout_s": 30,
    "readiness_poll_s": 0.5,
    "enable_thinking": true,
    "auth_header": "",
    "tls_verify": true,
    "ca_bundle_path": "",
    "allow_cross_host_endpoints": false,
    "max_tokens": null,
    "context_budget_max_tokens": 1024,
    "max_action_depth": 10,
    "fast_tool_finalize": true,
    "fast_finalize_tools": [
      "create_file",
      "edit_file",
      "delete_file"
    ]
  },
  "workspace": {
    "path": "~/Desktop/Alphanus-Workspace"
  },
  "memory": {
    "path": "./memories/memory.pkl"
  },
  "context": {
    "context_limit": 8192,
    "keep_last_n": 10,
    "safety_margin": 500
  },
  "capabilities": {
    "shell_require_confirmation": true,
    "email_enabled": false,
    "email_imap_server": "imap.gmail.com"
  },
  "skills": {
    "selection_mode": "all_enabled",
    "max_active_skills": 6,
    "strict_capability_policy": false
  },
  "whatsapp": {
    "enabled": false
  }
}
